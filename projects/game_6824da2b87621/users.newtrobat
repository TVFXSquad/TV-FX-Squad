<?php
session_start();

// Установка начальных переменных
$users_file = 'otdhenfd.txt';
$messages_file = 'messages.txt';

// Регистрация пользователя
if (isset($_POST['register'])) {
    $username = $_POST['username'];
    $password = $_POST['password'];
    $avatar = $_FILES['avatar'];

    if (!file_exists('uploads')) {
        mkdir('uploads', 0777, true);
    }

    $upload_path = 'uploads/' . basename($avatar['name']);
    move_uploaded_file($avatar['tmp_name'], $upload_path);

    $user_data = "$username|$password|Free|$upload_path\n";
    file_put_contents($users_file, $user_data, FILE_APPEND);
    mkdir($username, 0777, true);
    file_put_contents("$username/profile.txt", "Имя: $username\nТариф: Free");
    header('Location: index.php');
    exit;
}

// Вход пользователя
if (isset($_POST['login'])) {
    $username = $_POST['username'];
    $password = $_POST['password'];
    $valid_user = false;

    $users = file($users_file);
    foreach ($users as $user) {
        list($uname, $upass, $plan, $avatar) = explode('|', trim($user));
        if ($uname === $username && $upass === $password) {
            $_SESSION['username'] = $uname;
            $_SESSION['plan'] = trim($plan);
            $_SESSION['avatar'] = trim($avatar);
            $valid_user = true;
            break;
        }
    }

    if (!$valid_user) {
        echo "Неверный логин или пароль.";
    } else {
        header('Location: index.php');
        exit;
    }
}

// Выход из аккаунта
if (isset($_POST['logout'])) {
    session_destroy();
    header('Location: index.php');
    exit;
}

// Общий чат
if (isset($_POST['message'])) {
    $msg = $_POST['message'];
    $username = $_SESSION['username'];
    $msg_line = "$username: $msg\n";
    file_put_contents($messages_file, $msg_line, FILE_APPEND);
}

// Отображение пользователей и чата
$users = file($users_file);
$messages = file_exists($messages_file) ? file($messages_file) : [];

?>

